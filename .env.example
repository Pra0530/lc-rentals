# 🚗 LC Rentals — Firebase Configuration Keys
# Copy this file to '.env.local' and replace placeholders with your actual Firebase Project keys.

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id-here
VITE_FIREBASE_APP_ID=1:your-app-id-here

# 📱 Twilio SMS Integration Keys (Optional - Fallback is mock simulation logs)
VITE_TWILIO_ACCOUNT_SID=your-twilio-sid-here
VITE_TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
VITE_TWILIO_PHONE_NUMBER=your-twilio-phone-number-here

# 💳 Stripe Payment Gateway Keys
VITE_STRIPE_PUBLISHABLE_KEY=your-publishable-key-here
STRIPE_SECRET_KEY=your-secret-key-here
STRIPE_WEBHOOK_SECRET=your-webhook-secret-here

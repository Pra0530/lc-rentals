rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Checks if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Checks if the user is the owner of the document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper: Checks if the user is an admin
    // Note: Since this is a client-side prototype, we can check if they have an admin claim
    // or if they are in the users collection with an admin role.
    function isAdmin() {
      return isSignedIn() && 
        (request.auth.token.role == 'admin' || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         // Fallback default admin access check for convenience in local testing
         request.auth.token.email.endsWith('@luxury.com') ||
         request.auth.token.email.endsWith('@lcrentals.com'));
    }

    // --- COLLECTION RULES ---

    // 1. Users Profile Collection
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn();
    }

    // 2. Fleet Collection
    match /fleet/{carId} {
      allow read: if true; // Everyone can view the fleet catalog
      allow write: if isAdmin(); // Only admins can add/update/delete vehicles
    }

    // 3. Bookings Collection
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn(); // Any authenticated user can create a booking
      allow update, delete: if isAdmin(); // Status modifications (approve/inspect) restricted to staff
    }

    // 4. Inquiries Collection
    match /inquiries/{inquiryId} {
      allow create: if true; // Anyone can submit a lead inquiry
      allow read, write: if isAdmin(); // Only admins can inspect and process lead lists
    }
  }
}
